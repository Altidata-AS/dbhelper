# DBHelper create:devdb is intended to be run on the host database server, not via remote access.
# I recommend reviewing/editing the column_template.json before running table:analyze

# DBHelper configuration
dbh_tablemapping=table_mapping.json
dbh_columnmapping=column_mapping.json
dbh_columntemplate=column_template.json
debug=true

# Database configuration
# Supported types: mysql, pgsql
db_type=mysql
db_host=
db_port=3306
db_name=
db_user=
db_password=

# Email configuration
smtp_host=smtp.altidata.net
smtp_port=587
smtp_secure=tls
smtp_auth=true
smtp_user=
smtp_password=
smtp_from_address=dbhelper@altidata.no
smtp_from_name=DBHelper